# ALT MAX Web — Variáveis de Ambiente
# Copie para .env.local e preencha com valores reais

# URL da API backend (Railway)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry (PR-11 / Fase 1B) — observabilidade do front. Vazio = SDK inerte.
# Obter DSN em https://sentry.io → projeto Next.js → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Default usa NODE_ENV (development/production)
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# Opcional, só para upload de source maps em build de produção (Vercel).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
